# 飞书 Webhook（多个群用英文逗号分隔）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/你的webhook地址

# RapidAPI Key（注册 rapidapi.com，订阅 tiktok-scraper7）
RAPIDAPI_KEY=你的RapidAPI Key

# Google Sheet ID（表格 URL 中 /d/ 后面那段）
GOOGLE_SHEET_ID=你的Google Sheet ID

# 发件人信息（出现在邮件签名里）
SENDER_NAME=你的姓名
BRAND_NAME=你的品牌名称
REPLY_EMAIL=你的联系邮箱

# SMTP 邮件发送配置（支持任意邮箱）
# Gmail: smtp.gmail.com / QQ邮箱: smtp.qq.com / 163: smtp.163.com / Outlook: smtp.office365.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# 支持多账号，用英文逗号分隔，密码顺序需与账号对应，每账号每日上限 500 封
SMTP_USER=account1@gmail.com,account2@gmail.com
SMTP_PASSWORD=密码1,密码2
